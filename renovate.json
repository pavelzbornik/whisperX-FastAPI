{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":separatePatchReleases"
  ],

  "baseBranches": ["dev"],
  "schedule": ["before 6am on the first Monday of the month"],
  "timezone": "UTC",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "labels": ["dependencies"],

  "commitMessagePrefix": "chore(deps):",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",

  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "labels": ["security", "dependencies"]
  },

  "uv": {
    "enabled": true
  },
  "docker": {
    "enabled": true
  },
  "pre-commit": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true,
    "pinDigests": true
  },

  "postUpdateOptions": ["uvLockFileMaintenance"],

  "packageRules": [

    {
      "description": "PyTorch ecosystem — hard ceiling, manual review only",
      "matchPackageNames": ["torch", "torchaudio", "torchvision"],
      "groupName": "PyTorch ecosystem",
      "allowedVersions": "<=2.8.0",
      "autoMerge": false,
      "labels": ["dependencies", "pytorch"],
      "reviewers": ["pavelzbornik"]
    },

    {
      "description": "huggingface-hub — critical pyannote.audio compat constraint",
      "matchPackageNames": ["huggingface-hub"],
      "allowedVersions": "<0.36.0",
      "autoMerge": false,
      "labels": ["dependencies", "ml-compat"]
    },

    {
      "description": "ML core libraries — manual review",
      "matchPackageNames": ["whisperx", "numba", "ctranslate2"],
      "groupName": "ML core libraries",
      "autoMerge": false,
      "labels": ["dependencies", "ml-core"]
    },

    {
      "description": "FastAPI ecosystem — minor+patch auto-merge",
      "matchPackageNames": ["fastapi", "uvicorn", "gunicorn", "httpx", "pydantic-settings", "python-multipart", "python-dotenv"],
      "groupName": "FastAPI ecosystem",
      "matchUpdateTypes": ["minor", "patch"],
      "autoMerge": true,
      "autoMergeType": "squash",
      "labels": ["dependencies", "fastapi"]
    },
    {
      "description": "FastAPI ecosystem — major manual review",
      "matchPackageNames": ["fastapi", "uvicorn", "gunicorn", "httpx", "pydantic-settings", "python-multipart", "python-dotenv"],
      "groupName": "FastAPI ecosystem",
      "matchUpdateTypes": ["major"],
      "autoMerge": false,
      "labels": ["dependencies", "fastapi"]
    },

    {
      "description": "Database stack — minor+patch auto-merge",
      "matchPackageNames": ["sqlalchemy", "aiosqlite", "asyncpg", "psycopg2-binary"],
      "groupName": "Database stack",
      "matchUpdateTypes": ["minor", "patch"],
      "autoMerge": true,
      "autoMergeType": "squash",
      "labels": ["dependencies", "database"]
    },
    {
      "description": "Database stack — major manual review",
      "matchPackageNames": ["sqlalchemy", "aiosqlite", "asyncpg", "psycopg2-binary"],
      "groupName": "Database stack",
      "matchUpdateTypes": ["major"],
      "autoMerge": false,
      "labels": ["dependencies", "database"]
    },

    {
      "description": "All dev tools — minor+patch auto-merge as one group",
      "matchPackageNames": [
        "ruff", "mypy", "codespell", "types-requests", "types-PyYAML", "pandas-stubs",
        "pytest", "pytest-asyncio", "pytest-cov", "factory-boy", "locust",
        "pre-commit", "commitizen", "setuptools", "wheel",
        "tqdm", "colorlog", "dependency-injector"
      ],
      "groupName": "Dev and utility tools",
      "matchUpdateTypes": ["minor", "patch"],
      "autoMerge": true,
      "autoMergeType": "squash",
      "labels": ["dependencies", "dev-tools"]
    },

    {
      "description": "nvidia/cuda base image — ignore, never update",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["nvidia/cuda"],
      "enabled": false
    },

    {
      "description": "Docker images (non-CUDA) — patch auto-merge",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["patch"],
      "autoMerge": true,
      "autoMergeType": "squash",
      "labels": ["dependencies", "docker"]
    },
    {
      "description": "Docker images (non-CUDA) — minor/major manual review",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "major"],
      "autoMerge": false,
      "labels": ["dependencies", "docker"]
    },

    {
      "description": "GitHub Actions — minor+patch auto-merge (SHA-pinned)",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "matchUpdateTypes": ["minor", "patch"],
      "autoMerge": true,
      "autoMergeType": "squash",
      "labels": ["dependencies", "github-actions"],
      "pinDigests": true
    },
    {
      "description": "GitHub Actions major — manual review",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "autoMerge": false,
      "labels": ["dependencies", "github-actions"],
      "pinDigests": true
    },

    {
      "description": "Pre-commit hooks — minor+patch auto-merge",
      "matchManagers": ["pre-commit"],
      "groupName": "Pre-commit hooks",
      "matchUpdateTypes": ["minor", "patch"],
      "autoMerge": true,
      "autoMergeType": "squash",
      "labels": ["dependencies", "pre-commit"]
    },
    {
      "description": "Pre-commit hooks major — manual review",
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["major"],
      "autoMerge": false,
      "labels": ["dependencies", "pre-commit"]
    }
  ]
}
