{
  "name": "WhisperX-FastAPI",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/whisperX-FastAPI",
  "shutdownAction": "stopCompose",

  "forwardPorts": [8000, 5432],
  // Features to add to the dev container. More info: https://containers.dev/features.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/dhoeric/features/hadolint:1": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.copilot",
        "charliermarsh.ruff",
        "github.vscode-github-actions",
        "george-alisson.html-preview-vscode",
        "ms-azuretools.vscode-docker",
        "SonarSource.sonarlint-vscode",
        "Anthropic.claude-code"
      ]
    }
  },
  "postCreateCommand": "chmod +x /workspaces/whisperX-FastAPI/.devcontainer/post-create.sh && /workspaces/whisperX-FastAPI/.devcontainer/post-create.sh",
  "postAttachCommand": "chmod +x /workspaces/whisperX-FastAPI/.devcontainer/post-attach.sh && /workspaces/whisperX-FastAPI/.devcontainer/post-attach.sh",
  "remoteUser": "root",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/bin",
    "UV_CACHE_DIR": "/workspaces/whisperX-FastAPI/.uv_cache",
    "UV_LINK_MODE": "copy",
    "PRE_COMMIT_HOME": "/workspaces/whisperX-FastAPI/.cache/pre-commit",
    "PRE_COMMIT_USE_UV": "0",
    "TEST_DB_URL": "postgresql://postgres:test@postgres/testdb"
  },
  "mounts": [
    "source=${env:USERPROFILE}\\.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
    "source=${env:USERPROFILE}\\.claude,target=/root/.claude,type=bind",
    "source=whisperx-gh-config,target=/root/.config/gh,type=volume",
    "source=${env:USERPROFILE}\\.claude.json,target=/root/.claude.json,type=bind",
    "source=${localWorkspaceFolder}/.uv_cache,target=/workspaces/whisperX-FastAPI/.uv_cache,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.cache/pre-commit,target=/workspaces/whisperX-FastAPI/.cache/pre-commit,type=bind,consistency=cached"
  ]
}
